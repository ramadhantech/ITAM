@model ITAM.Models.Asset

@{
    ViewData["Title"] = "Rincian Data Asset";
}

<div class="container mt-4">
    <!-- HEADER & AKSI CEPAT -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Rincian Informasi Asset</h2>
            <p class="text-muted small mb-0">Informasi spesifikasi lengkap, lokasi penempatan, dan status operasional perangkat</p>
        </div>
        <div class="gap-1 d-flex">
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                Kembali ke Daftar
            </a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning btn-sm fw-bold text-dark">
                Ubah Asset
            </a>
        </div>
    </div>

    <div class="row">
        <!-- SEKTOR UTAMA: DETAIL PERANGKAT -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0">Spesifikasi & Identitas Asset</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Asset Tag</span>
                            <span class="fw-bold text-primary fs-5">@Model.AssetTag</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Nama Asset</span>
                            <span class="fw-bold text-dark fs-5">@Model.AssetName</span>
                        </div>
                        <hr class="my-2 text-muted">
                        <div class="col-sm-4">
                            <span class="text-muted small d-block">Kategori</span>
                            <span class="fw-medium text-dark">@Model.Category?.Name</span>
                        </div>
                        <div class="col-sm-4">
                            <span class="text-muted small d-block">Tipe Asset</span>
                            <span class="fw-medium text-dark">@Model.AssetType</span>
                        </div>
                        <div class="col-sm-4">
                            <span class="text-muted small d-block">Lokasi Penyimpanan</span>
                            <span class="fw-medium text-dark">📍 @Model.Location?.Name</span>
                        </div>
                        <hr class="my-2 text-muted">
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Penanggung Jawab / User (Dept)</span>
                            <span class="fw-medium text-dark">👤 @Model.User?.Department</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Catatan Tambahan</span>
                            <p class="text-muted small mb-0">@(string.IsNullOrEmpty(Model.Note) ? "-" : Model.Note)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SEKTOR SAMPING: INDIKATOR STATUS & AUDIT SYSTEM -->
        <div class="col-md-4">
            <!-- STATUS OPERASIONAL -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4 text-center">
                    <span class="text-muted small d-block mb-2">Status & Kondisi Terakhir</span>

                    <!-- Status Badge -->
                    @{
                        var statusClass = Model.Status?.ToLower() == "deployed" || Model.Status?.ToLower() == "active"
                        ? "bg-success-subtle text-success border border-success-subtle"
                        : "bg-warning-subtle text-warning border border-warning-subtle";
                    }
                    <div class="badge px-3 py-2 @statusClass text-uppercase fs-7 mb-2 w-100 d-block">
                        Status: @Model.Status
                    </div>

                    <!-- Condition Badge -->
                    @{
                        var condLower = Model.Condition?.ToLower() ?? "";
                        string condClass = condLower == "bagus" || condLower == "good" || condLower == "baik"
                        ? "bg-success-subtle text-success border border-success-subtle"
                        : (condLower == "rusak" || condLower == "rusak ringan" || condLower == "broken"
                        ? "bg-warning-subtle text-warning border border-warning-subtle"
                        : "bg-danger-subtle text-danger border border-danger-subtle");
                    }
                    <div class="badge px-3 py-2 @condClass text-uppercase fs-7 w-100 d-block">
                        Kondisi: @Model.Condition
                    </div>
                </div>
            </div>

            <!-- AUDIT JALUR SISTEM -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light py-2">
                    <span class="fw-bold small text-muted text-uppercase">Informasi Sistem</span>
                </div>
                <div class="card-body p-3 fs-7">
                    <div class="mb-2">
                        <span class="text-muted d-block small">Terdaftar Oleh (Dept)</span>
                        <span class="text-dark">@Model.CreatedByUser?.Department</span>
                    </div>
                    <div class="mb-2">
                        <span class="text-muted d-block small">Tanggal Dibuat</span>
                        <span class="text-dark">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                    </div>
                    <div>
                        <span class="text-muted d-block small">Pembaruan Terakhir</span>
                        <span class="text-dark">@Model.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-7 {
        font-size: 0.82rem !important;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }

    .bg-danger-subtle {
        background-color: #f8d7da !important;
    }
</style>
