@model IEnumerable<ITAM.Models.Asset>

@{
    ViewData["Title"] = "Daftar Asset";
}

<div class="container-fluid mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Manajemen Asset</h1>
            <p class="text-muted small mb-0">
                Kelola dan pantau seluruh aset inventaris perusahaan
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            Tambah Asset Baru
        </a>
    </div>

    <!-- FILTER -->
    <div class="card shadow-sm border-0 mb-3 bg-light">
        <div class="card-body p-3">

            <form asp-action="Index" method="get" class="row g-2 align-items-center">

                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white">🔍</span>
                        <input type="text"
                               name="search"
                               class="form-control"
                               value="@ViewBag.CurrentSearch"
                               placeholder="Cari Asset..." />
                    </div>
                </div>

                <div class="col-md-3">
                    <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                        <option value="">-- Semua Kategori --</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <select name="locationId" class="form-select" asp-items="ViewBag.Locations">
                        <option value="">-- Semua Lokasi --</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>

            </form>

        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0 text-nowrap">

                    <thead class="table-light text-uppercase fs-7 fw-bold border-bottom">
                        <tr>
                            <th>Asset Tag</th>
                            <th>Nama Asset</th>
                            <th>Serial Number</th>
                            <th>Vendor</th>
                            <th>Contract</th>
                            <th>Kategori</th>
                            <th>Lokasi</th>
                            <th>User</th>
                            <th>Tipe</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Kondisi</th>
                            <th>Tanggal</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="13" class="text-center py-5 text-muted">
                                    Belum ada data asset.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>

                                    <!-- ASSET TAG -->
                                    <td class="fw-bold text-primary">
                                        @item.AssetTag
                                    </td>

                                    <!-- NAME -->
                                    <td>
                                        <div class="fw-bold">@item.AssetName</div>
                                        <div class="text-muted small">@item.Note</div>
                                    </td>

                                    <!-- SERIAL NUMBER -->
                                    <td class="font-monospace">
                                        @(item.SerialNumber ?? "-")
                                    </td>

                                    <!-- VENDOR -->
                                    <td>
                                        @(item.ContractName?.Vendor?.VendorName ?? "-")
                                    </td>

                                    <!-- CONTRACT -->
                                    <td>
                                        @(item.ContractName?.ContractNumber ?? "-")
                                    </td>

                                    <!-- CATEGORY -->
                                    <td>@item.Category?.Name</td>

                                    <!-- LOCATION -->
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @item.Location?.Name
                                        </span>
                                    </td>

                                    <!-- USER -->
                                    <td>@item.User?.Name</td>

                                    <!-- TYPE -->
                                    <td>
                                        @(item.AssetType == "Buy" ? "Asset (Milik)" : "Sewa")
                                    </td>

                                    <!-- STATUS -->
                                    <td class="text-center">
                                        <span class="badge bg-success">
                                            @item.Status
                                        </span>
                                    </td>

                                    <!-- CONDITION -->
                                    <td class="text-center">
                                        <span class="badge bg-warning text-dark">
                                            @item.Condition
                                        </span>
                                    </td>

                                    <!-- CREATED -->
                                    <td>
                                        @item.CreatedAt.ToString("dd MMM yyyy")
                                    </td>

                                    <!-- ACTION -->
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                            <i class="fa fa-eye"></i>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fa fa-edit"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Hapus asset ini?')">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

</div>