@model ITAM.Models.Category

@{
    ViewData["Title"] = "Tambah Kategori";
}

<div class="container mt-4" style="max-width: 600px;">
    <!-- HEADER & BUTTON KEMBALI -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Tambah Kategori Baru</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Kembali
        </a>
    </div>

    <!-- TAMPILAN UTAMA DALAM BENTUK CARD -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="card-title mb-0"><i class="bi bi-tag-fill me-2"></i>Formulir Kategori Baru</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                <!-- INPUT FIELD NAMA KATEGORI -->
                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-bold">Nama Kategori</label>
                    <input asp-for="Name" class="form-control form-control-lg" placeholder="Contoh: Laptop, Monitor, Software License" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-grid border-top pt-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle me-1"></i> Simpan Kategori
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
