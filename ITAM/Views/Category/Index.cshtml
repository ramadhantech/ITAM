@model IEnumerable<ITAM.Models.Category>

@{
    ViewData["Title"] = "Kategori Asset";
}

<div class="container-fluid mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Kategori Asset</h1>
            <p class="text-muted small mb-0">
                Kelola kelompok atau jenis inventaris perangkat IT
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Tambah Kategori
        </a>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light text-uppercase fs-7 fw-bold border-bottom">
                        <tr>
                            <th class="ps-4" style="width: 75%;">Nama Kategori</th>
                            <th class="text-center pe-4" style="width: 25%;">Aksi</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="2" class="text-center py-5 text-muted">
                                    Belum ada data kategori yang terdaftar.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int no = (ViewBag.Page - 1) * ViewBag.PageSize + 1;

                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-dark">
                                        <i class="bi bi-tag-fill text-secondary me-2"></i>
                                        @item.Name
                                    </td>

                                    <td class="text-center pe-4">

                                        <div class="btn-group gap-1">

                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fa fa-edit"></i>
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-route-id="@item.Id"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Hapus kategori @item.Name?')">
                                                    <i class="fa fa-trash"></i>
                                                </button>

                                            </form>

                                        </div>

                                    </td>
                                </tr>

                                no++;
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

    <!-- PAGINATION -->
    <nav class="mt-3">
        <ul class="pagination justify-content-end">

            <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page - 1)">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page + 1)">
                    Next
                </a>
            </li>

        </ul>
    </nav>

</div>
