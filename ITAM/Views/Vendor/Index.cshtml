@model List<ITAM.Dto.VendorDto>

@{
    ViewData["Title"] = "Vendor Management";
}

<div class="container-fluid mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Vendor Management</h2>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Vendor
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">

            <table class="table table-bordered table-striped mb-0">

                <thead>
                    <tr>
                        <th width="80">No</th>
                        <th>Nama Vendor</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                No vendor data found
                            </td>
                        </tr>
                    }
                    else
                    {
                        int no = (ViewBag.Page - 1) * ViewBag.PageSize + 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@no</td>
                                <td>@item.VendorName</td>
                                <td>
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <form asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          class="d-inline">

                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('Delete this vendor?')">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            no++;
                        }
                    }

                </tbody>

            </table>

        </div>
    </div>

    <!-- PAGINATION -->
    <nav class="mt-3">
        <ul class="pagination justify-content-end">

            <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page - 1)">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page + 1)">
                    Next
                </a>
            </li>

        </ul>
    </nav>

</div>