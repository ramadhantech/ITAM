@model IEnumerable<ITAM.Models.User>

@{
    ViewData["Title"] = "Manajemen User";
}

<div class="container-fluid mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Manajemen Pengguna</h1>
            <p class="text-muted small mb-0">
                Kelola hak akses, departemen, dan data penanggung jawab aset
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus-fill me-1"></i> Tambah Pengguna
        </a>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0 text-nowrap">

                    <thead class="table-light text-uppercase fs-7 fw-bold border-bottom">
                        <tr>
                            <th class="ps-4">Nama</th>
                            <th>Email</th>
                            <th>Departement</th>
                            <th>Lokasi</th>
                            <th class="text-center">Role</th>
                            <th>Tanggal</th>
                            <th class="text-center pe-4">Aksi</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    Belum ada data pengguna
                                </td>
                            </tr>
                        }
                        else
                        {
                            int no = (ViewBag.Page - 1) * ViewBag.PageSize + 1;

                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- NAME -->
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center fw-bold me-3"
                                                 style="width:38px;height:38px;">
                                                @(string.IsNullOrEmpty(item.Name) ? "?" : item.Name.Substring(0, 1).ToUpper())
                                            </div>

                                            <div class="fw-bold">
                                                @item.Name
                                            </div>
                                        </div>
                                    </td>

                                    <!-- EMAIL -->
                                    <td class="text-muted">
                                        @item.Email
                                    </td>

                                    <!-- DEPARTMENT -->
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @(item.Department?.Name ?? "-")
                                        </span>
                                    </td>

                                    <!-- LOCATION -->
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @(item.Location?.Name ?? "-")
                                        </span>
                                    </td>

                                    <!-- ROLE -->
                                    <td class="text-center">
                                        @{
                                            var roleLower = item.Role?.ToLower();
                                            var roleClass = roleLower == "admin"
                                            ? "bg-success-subtle text-success border"
                                            : "bg-info-subtle text-info border";
                                        }

                                        <span class="badge @roleClass px-3 py-1 text-uppercase">
                                            @item.Role
                                        </span>
                                    </td>

                                    <!-- DATE -->
                                    <td>
                                        @item.CreatedAt.ToString("dd MMM yyyy")
                                    </td>

                                    <!-- ACTION -->
                                    <td class="text-center pe-4">

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fa fa-pencil"></i>
                                        </a>

                                        <form asp-action="Delete"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Hapus user ini?')">
                                                <i class="fa fa-trash"></i>
                                            </button>

                                        </form>

                                    </td>

                                </tr>

                                no++;
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- PAGINATION -->
    <nav class="mt-3">
        <ul class="pagination justify-content-end">

            <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page - 1)">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page + 1)">
                    Next
                </a>
            </li>

        </ul>
    </nav>

</div>

