@model IEnumerable<ITAM.Models.Contract>

@{
    ViewData["Title"] = "Contract Management";
}

<div class="container-fluid mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Contract Management</h2>

        <a asp-action="Create" class="btn btn-primary">
            Add Contract
        </a>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-bordered table-striped mb-0">

                    <thead>
                        <tr>
                            <th>No</th>
                            <th>Nomor Kontrak</th>
                            <th>Vendor</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th width="180">Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    No contract data found
                                </td>
                            </tr>
                        }
                        else
                        {
                            int no = (ViewBag.Page - 1) * ViewBag.PageSize + 1;

                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@no</td>
                                    <td>@item.ContractNumber</td>
                                    <td>@item.Vendor?.VendorName</td>
                                    <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.EndDate.ToString("yyyy-MM-dd")</td>

                                    <td>
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-warning btn-sm">
                                            Edit
                                        </a>

                                        <form asp-action="Delete"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="d-inline">

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Delete this contract?')">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>

                                no++;
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

    <!-- PAGINATION -->
    <nav class="mt-3">
        <ul class="pagination justify-content-end">

            <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page - 1)">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.Page + 1)">
                    Next
                </a>
            </li>

        </ul>
    </nav>

</div>