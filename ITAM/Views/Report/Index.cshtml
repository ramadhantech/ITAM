@model List<ITAM.Models.Asset>

@{
    ViewData["Title"] = "Asset Report";

    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalItems = ViewBag.TotalItems ?? 0;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);

    int? currentLocation = ViewBag.CurrentLocation;
    int? currentCategory = ViewBag.CurrentCategory;
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">


        <div>
            <span class="badge bg-primary fs-6 px-3 py-2">
                Total Data : @totalItems
            </span>
        </div>

    </div>

    <!-- FILTER -->
    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <form method="get" asp-action="Index">

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Lokasi
                        </label>
                        <select name="locationId"
                                class="form-select"
                                asp-items="ViewBag.Locations">
                            <option value="">Semua Lokasi</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Kategori
                        </label>
                        <select name="categoryId"
                                class="form-select"
                                asp-items="ViewBag.Categories">
                            <option value="">Semua Kategori</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Aksi
                        </label>

                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-primary flex-grow-1">
                                <i class="fa fa-filter me-1"></i>
                                Filter Data
                            </button>

                            <a asp-action="ExportExcel"
                               asp-route-locationId="@ViewBag.CurrentLocation"
                               asp-route-categoryId="@ViewBag.CurrentCategory"
                               class="btn btn-success">
                                <i class="fa fa-file-excel me-1"></i>
                                Export
                            </a>

                        </div>
                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th class="ps-4">Asset Tag</th>
                            <th>Asset Name</th>
                            <th>Category</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Condition</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (Model == null || !Model.Any())
                        {
                            <tr>

                                <td colspan="6"
                                    class="text-center py-5 text-muted">

                                    <i class="bi bi-inbox display-6 d-block mb-3"></i>

                                    Tidak ada data asset ditemukan

                                </td>

                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                string conditionClass =
                                item.Condition?.ToLower() == "good"
                                ? "bg-success"
                                : "bg-danger";

                                <tr>

                                    <td class="ps-4">

                                        <span class="fw-bold text-primary">
                                            @item.AssetTag
                                        </span>

                                    </td>

                                    <td>

                                        <div class="fw-semibold">
                                            @item.AssetName
                                        </div>

                                    </td>

                                    <td>

                                        <span class="badge bg-light text-dark border">
                                            @(item.Category?.Name ?? "-")
                                        </span>

                                    </td>

                                    <td>

                                        <span class="badge bg-light text-dark border">
                                            @(item.Location?.Name ?? "-")
                                        </span>

                                    </td>

                                    <td>

                                        <span class="badge bg-info">
                                            @(item.Status ?? "-")
                                        </span>

                                    </td>

                                    <td>

                                        <span class="badge @conditionClass">
                                            @(item.Condition ?? "-")
                                        </span>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- PAGINATION -->
    @if (totalPages > 1)
    {
        <nav class="mt-4">

            <ul class="pagination justify-content-center">

                <!-- PREVIOUS -->
                <li class="page-item @(page <= 1 ? "disabled" : "")">

                    <a class="page-link"
                       asp-action="ByLocation"
                       asp-route-locationId="@currentLocation"
                       asp-route-categoryId="@currentCategory"
                       asp-route-page="@(page - 1)">

                        Previous

                    </a>

                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">

                        <a class="page-link"
                           asp-action="ByLocation"
                           asp-route-locationId="@currentLocation"
                           asp-route-categoryId="@currentCategory"
                           asp-route-page="@i">

                            @i

                        </a>

                    </li>
                }

                <!-- NEXT -->
                <li class="page-item @(page >= totalPages ? "disabled" : "")">

                    <a class="page-link"
                       asp-action="ByLocation"
                       asp-route-locationId="@currentLocation"
                       asp-route-categoryId="@currentCategory"
                       asp-route-page="@(page + 1)">

                        Next

                    </a>

                </li>

            </ul>

        </nav>
    }

</div>