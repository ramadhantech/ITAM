@model IEnumerable<ITAM.Models.InspectionReport>

@{
    ViewData["Title"] = "Inspection Reports";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="h2 fw-bold text-dark mb-1">
                Inspection Reports
            </h1>

            <p class="text-muted mb-0">
                Manage and monitor all asset inspection records.
            </p>
        </div>

        <div>
            <a asp-action="Create"
               class="btn btn-primary shadow-sm">

                <i class="bi bi-plus-lg me-2"></i>
                Create New Report
            </a>
        </div>

    </div>

    <!-- CARD -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <!-- TABLE HEADER -->
                    <thead class="table-light">

                        <tr class="text-uppercase small text-muted">

                            <th class="ps-4">
                                Report Number
                            </th>

                            <th>
                                Title
                            </th>

                            <th>
                                Inspection Date
                            </th>

                            <th>
                                Location
                            </th>

                            <th>
                                Creator
                            </th>

                            <th>
                                Status
                            </th>

                            <th>
                                Approved At
                            </th>

                            <th class="text-end pe-4">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <!-- TABLE BODY -->
                    <tbody>

                        @if (Model == null || !Model.Any())
                        {
                            <tr>

                                <td colspan="8"
                                    class="text-center py-5 text-muted">

                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>

                                    <h5 class="fw-semibold">
                                        No Inspection Reports
                                    </h5>

                                    <p class="mb-0">
                                        There are no inspection reports available.
                                    </p>

                                </td>

                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                var statusClass = item.ApprovalStatus?.ToLower() switch
                                {
                                    "approved" => "bg-success-subtle text-success border-success-subtle",

                                    "pending" => "bg-warning-subtle text-warning border-warning-subtle",

                                    "rejected" => "bg-danger-subtle text-danger border-danger-subtle",

                                    _ => "bg-secondary-subtle text-secondary border-secondary-subtle"
                                };

                                <tr>

                                    <!-- REPORT NUMBER -->
                                    <td class="ps-4 fw-bold text-secondary">

                                        @item.ReportNumber

                                    </td>

                                    <!-- TITLE -->
                                    <td>

                                        <span class="fw-semibold text-dark d-block">

                                            @item.Title

                                        </span>

                                        <small class="text-muted">

                                            Created:
                                            @item.CreatedAt.ToString("dd MMM yyyy")

                                        </small>

                                    </td>

                                    <!-- DATE -->
                                    <td>

                                        @item.InspectionDate.ToString("dd MMM yyyy")

                                    </td>

                                    <!-- LOCATION -->
                                    <td>

                                        <span class="badge bg-light text-dark border px-3 py-2">

                                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>

                                            @(item.Location?.Name ?? "-")

                                        </span>

                                    </td>

                                    <!-- CREATOR -->
                                    <td>

                                        <span class="fw-semibold text-dark d-block">

                                            @(item.Creator?.Name ?? "-")

                                        </span>

                                        <small class="text-muted d-block">

                                            Dept:
                                            @(item.Creator?.Department?.Name ?? "-")

                                        </small>

                                        <small class="text-muted d-block">

                                            Approver:
                                            @(item.Approver?.Name ?? "-")

                                        </small>

                                    </td>

                                    <!-- STATUS -->
                                    <td>

                                        <span class="badge border rounded-pill px-3 py-2 @statusClass">

                                            @(item.ApprovalStatus ?? "-")

                                        </span>

                                    </td>

                                    <!-- APPROVED DATE -->
                                    <td class="text-muted small">

                                        @(item.ApprovedAt.HasValue
                                                                        ? item.ApprovedAt.Value.ToString("dd MMM yyyy HH:mm")
                                                                        : "-")

                            </td>

                                    <!-- ACTIONS -->
                                    <td class="text-end pe-4">

                                        <div class="btn-group">

                                            <!-- TOMBOL CETAK BA (BERITA ACARA) -->
                                            <a asp-action="Print"
                                               asp-route-id="@item.Id"
                                               target="_blank"
                                               class="btn btn-sm btn-outline-dark"
                                               title="Print Berita Acara">
                                                <i class="bi bi-printer-fill"></i>
                                            </a>

                                            <!-- DETAILS -->
                                            <a asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-secondary"
                                               title="Details">

                                                <i class="bi bi-eye"></i>

                                            </a>

                                            <!-- EDIT -->
                                    @if (item.ApprovalStatus != "Approved")
                                            {
                                                <a asp-action="Edit"
                                                   asp-route-id="@item.Id"
                                                   class="btn btn-sm btn-outline-primary"
                                                   title="Edit">

                                                    <i class="bi bi-pencil"></i>

                                                </a>
                                            }
                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>
